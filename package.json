{
	"name": "tsdom",
	"type": "module",
	"version": "1.0.0",
	"description": "A modern TypeScript implementation of the WhatWG DOM spec",
	"author": "Rob Hameetman <engineering@robhameetman.com>",
	"homepage": "https://www.robhameetman.com",
	"license": "UNLICENSED",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RobHameetman/tsdom.git"
	},
	"main": "./dist/index.js",
	"module": "./src/index.ts",
	"typings": "./dist/index.d.ts",
	"imports": {
		"#$/*": "./test/resources/*",
		"#*": "./src/*"
	},
	"scripts": {
		"format": "eslint ./src/* --ext=ts --fix",
		"reset": "NODE_ENV=production rm -rf ./dist && npm run build -- --force",
		"test": "NODE_ENV=testing rstest run -c ./test/config/rstest.config.ts",
		"test:watch": "NODE_ENV=testing rstest watch -c ./test/config/rstest.config.ts"
	},
	"devDependencies": {
		"@rstest/core": "^0.10.6",
		"@types/node": "^22.19.0",
		"typescript": "^6.0.3"
	}
}
